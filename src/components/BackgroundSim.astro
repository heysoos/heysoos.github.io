---
// src/components/BackgroundSim.astro
// Fixed-viewport background simulation component.
// Renders a position:fixed canvas behind all page content.
// Initialises the sim controller and wires ObstacleTracker for density voids.

interface Props {
  sim: 'boids';
}

const { sim } = Astro.props;
---

<canvas id="bg-sim-canvas"></canvas>
<canvas id="bg-sim-debug" aria-hidden="true"></canvas>

<div id="preset-picker">
  <button id="preset-trigger" title="Switch preset" aria-label="Switch boids preset">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="22,12 8,4 8,20"/>
      <line x1="1" y1="9"  x2="6" y2="9"  stroke-opacity="0.45"/>
      <line x1="1" y1="12" x2="6" y2="12" stroke-opacity="0.75"/>
      <line x1="1" y1="15" x2="6" y2="15" stroke-opacity="0.45"/>
    </svg>
  </button>
  <div id="preset-menu" role="menu" aria-hidden="true"></div>
</div>

<style>
  #bg-sim-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  #bg-sim-debug {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
    display: none;
  }
  #preset-picker {
    position: fixed;
    top: calc(60px + 0.75rem);
    right: 1rem;
    z-index: 101;
  }
  #preset-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px 8px;
    background: transparent;
    border: 1px solid var(--bg-surface-border);
    border-radius: 8px;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  #preset-trigger:hover {
    color: var(--text-primary);
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
  #preset-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: 10px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 140px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.12s, transform 0.12s;
  }
  #preset-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
</style>

<script>
  import { BoidsController } from './simulations/boids/boids-controller';
  import { ObstacleTracker } from '../lib/webgpu/obstacle-tracker';
  import { BOIDS_PRESETS } from '../data/boids-presets';

  const canvas = document.getElementById('bg-sim-canvas') as HTMLCanvasElement;
  const debugCanvas = document.getElementById('bg-sim-debug') as HTMLCanvasElement;
  const debugCtx = debugCanvas.getContext('2d')!;

  // Debug overlay — toggle in console: window.__bgSimDebug = true
  const FALLOFF_NDC = 0.35;
  let lastRects = new Float32Array(0);
  let lastCount = 0;

  function drawDebug() {
    const w = window.innerWidth;
    const h = window.innerHeight;
    debugCanvas.width  = w;
    debugCanvas.height = h;
    debugCtx.clearRect(0, 0, w, h);

    for (let i = 0; i < lastCount; i++) {
      const cx = lastRects[i * 4 + 0];
      const cy = lastRects[i * 4 + 1];
      const hw = lastRects[i * 4 + 2];
      const hh = lastRects[i * 4 + 3];

      // NDC → screen pixels (y flipped: NDC y+ is up, canvas y+ is down)
      const sx = (cx - hw + 1) / 2 * w;
      const sy = (1 - cy - hh) / 2 * h;
      const sw = hw * w;
      const sh = hh * h;

      // Falloff halo
      const px = FALLOFF_NDC * w / 2;
      const py = FALLOFF_NDC * h / 2;
      debugCtx.strokeStyle = 'rgba(255, 80, 80, 0.25)';
      debugCtx.lineWidth = 1;
      debugCtx.setLineDash([4, 4]);
      debugCtx.strokeRect(sx - px, sy - py, sw + px * 2, sh + py * 2);
      debugCtx.setLineDash([]);

      // Rect fill
      debugCtx.fillStyle = 'rgba(255, 40, 40, 0.15)';
      debugCtx.fillRect(sx, sy, sw, sh);

      // Rect outline
      debugCtx.strokeStyle = 'rgba(255, 60, 60, 0.8)';
      debugCtx.lineWidth = 1.5;
      debugCtx.strokeRect(sx, sy, sw, sh);
    }
  }

  function debugLoop() {
    if ((window as any).__bgSimDebug) {
      debugCanvas.style.display = 'block';
      drawDebug();
    } else {
      debugCanvas.style.display = 'none';
    }
    requestAnimationFrame(debugLoop);
  }
  debugLoop();

  const controller = new BoidsController();
  const ok = await controller.init(canvas);

  if (ok) {
    // Apply the default preset (isDefault: true), falling back to first preset
    const defaultPreset = BOIDS_PRESETS.find(p => p.isDefault) ?? BOIDS_PRESETS[0];
    let activePresetId = defaultPreset.id;

    // ── Preset picker UI ─────────────────────────────────────────────
    const trigger = document.getElementById('preset-trigger')!;
    const menu    = document.getElementById('preset-menu')!;

    function updatePills(): void {
      for (const btn of menu.querySelectorAll<HTMLButtonElement>('button')) {
        const isActive = btn.dataset.id === activePresetId;
        btn.style.cssText = [
          'padding:2px 8px',
          'border-radius:12px',
          'font-size:0.68rem',
          'cursor:pointer',
          'transition:background 0.15s,color 0.15s',
          'text-align:left',
          'width:100%',
          isActive
            ? 'background:var(--accent);color:var(--bg-primary);border:1px solid transparent;'
            : 'background:transparent;color:var(--text-muted);border:1px solid transparent;',
        ].join(';');
      }
    }

    async function applyPreset(preset: typeof BOIDS_PRESETS[0]): Promise<void> {
      Object.assign(controller.params, preset.params);
      controller.trailsEnabled = preset.trailsEnabled;
      controller.trailDecay    = preset.trailDecay;
      if (preset.shader) await controller.reloadShader(preset.shader);
      activePresetId = preset.id;
      updatePills();
    }

    for (const preset of BOIDS_PRESETS) {
      const pill = document.createElement('button');
      pill.dataset.id  = preset.id;
      pill.textContent = preset.name;
      pill.setAttribute('role', 'menuitem');
      pill.addEventListener('click', async () => {
        await applyPreset(preset);
        closeMenu();
      });
      menu.appendChild(pill);
    }

    await applyPreset(defaultPreset);

    let menuOpen = false;
    function openMenu():  void { menuOpen = true;  menu.classList.add('open');    menu.setAttribute('aria-hidden', 'false'); }
    function closeMenu(): void { menuOpen = false; menu.classList.remove('open'); menu.setAttribute('aria-hidden', 'true');  }

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      menuOpen ? closeMenu() : openMenu();
    });

    document.addEventListener('click', () => { if (menuOpen) closeMenu(); });
    menu.addEventListener('click', (e) => e.stopPropagation());

    // ── ObstacleTracker ──────────────────────────────────────────────
    const tracker = new ObstacleTracker(
      ['.content-width', '.hero-text'],
      (rects, count) => {
        lastRects = rects;
        lastCount = count;
        controller.setObstacles(rects, count);
      },
    );
    tracker.start();

    controller.start();
  }
</script>
