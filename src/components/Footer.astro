---
import { siteConfig } from '../config';
---

<footer class="footer">
  <div class="footer-inner">
    <p>&copy; {new Date().getFullYear()} {siteConfig.name}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--bg-surface-border);
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer p {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
