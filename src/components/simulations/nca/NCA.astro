---
// src/components/simulations/nca/NCA.astro
---
<div class="sim-container">
  <canvas id="nca-canvas" style="image-rendering: pixelated;"></canvas>
  <div id="nca-fallback" class="fallback" style="display:none;">
    <p>WebGPU is not supported in your browser.</p>
  </div>
</div>

<style>
  .sim-container { position: relative; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--bg-primary); }
  canvas { display: block; max-width: 100%; max-height: 100%; object-fit: contain; }
  .fallback {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: var(--bg-primary); color: var(--text-muted);
  }
</style>
